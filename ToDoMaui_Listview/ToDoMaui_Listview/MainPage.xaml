<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ToDoMaui_Listview.MainPage"
    BackgroundColor="Black"
    Title="To-Do List">

    <VerticalStackLayout Spacing="10" Padding="10">

        <!-- Input Area -->
        <Frame BackgroundColor="White" CornerRadius="10" Padding="10" HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Entry x:Name="titleEntry" Placeholder="Title" PlaceholderColor="Gray" TextColor="Black" MaxLength="50"/>
                <Editor x:Name="detailsEditor" Placeholder="Details" PlaceholderColor="Gray" TextColor="Black" MaxLength="240" HeightRequest="100"/>

                <HorizontalStackLayout Spacing="10">
                    <Button x:Name="addBtn" Text="Add" BackgroundColor="LightBlue" TextColor="Black" Clicked="AddToDoItem"/>
                    <Button x:Name="editBtn" Text="Edit" BackgroundColor="LightGray" TextColor="Black" IsVisible="False" Clicked="EditToDoItem"/>
                    <Button x:Name="cancelBtn" Text="Cancel" BackgroundColor="LightCoral" TextColor="Black" IsVisible="False" Clicked="CancelEdit"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- To-Do List -->
        <ListView x:Name="todoLV"
                  HasUnevenRows="True"
                  SeparatorVisibility="Default"
                  BackgroundColor="Transparent"
                  ItemSelected="TodoLV_OnItemSelected"
                  ItemsSource="{Binding}"
                  Margin="0,0,0,10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame CornerRadius="10" Padding="10" Margin="5" BackgroundColor="White" HasShadow="True">
                            <Grid VerticalOptions="FillAndExpand" RowSpacing="5" ColumnSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Title and Detail -->
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding title}" FontSize="16" LineBreakMode="TailTruncation" TextColor="Black"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding detail}" FontSize="14" LineBreakMode="TailTruncation" TextColor="Black"/>

                                <!-- Delete Button -->
                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                        ImageSource="trash.png"
                                        BackgroundColor="Black"
                                        ClassId="{Binding id}"
                                        Clicked="DeleteToDoItem"
                                HeightRequest="70"
             WidthRequest="70"
             HorizontalOptions="Center"
             VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>
</ContentPage>